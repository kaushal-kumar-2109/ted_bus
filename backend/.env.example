# ===========================
# Database
# ===========================
MONGODB_URI=mongodb+srv://admin:admin@tedbus.vqk1yid.mongodb.net/?retryWrites=true&w=majority&appName=tedbus
DB_NAME=redbus_clone

# ===========================
# Server
# ===========================
NODE_ENV=development
PORT=5000
HOST=localhost

# ===========================
# JWT (CHANGE THESE IN PRODUCTION!)
# ===========================
JWT_SECRET=redbus_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=redbus_refresh_secret_change_in_production
JWT_REFRESH_EXPIRE=30d

# ===========================
# App URL (used for share links & email)
# ===========================
APP_URL=http://localhost:4200

# ===========================
# Email (Optional — for verification/reset emails)
# ===========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# ===========================
# Cloudinary (Optional — for image uploads)
# ===========================
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_KEY=your_cloudinary_api_key
CLOUDINARY_SECRET=your_cloudinary_api_secret

# ===========================
# CORS
# ===========================
CORS_ORIGIN=http://localhost:4200,http://localhost:3000

# ===========================
# API
# ===========================
API_VERSION=v1

# ===========================
# Rate Limiting
# ===========================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=200

# ===========================
# Community Features
# ===========================
MAX_POST_LENGTH=10000
MAX_COMMENT_LENGTH=2000
VERIFICATION_REQUIRED=true

# ===========================
# Admin Seed (for creating initial admin user)
# ===========================
ADMIN_EMAIL=admin@redbus-clone.in
ADMIN_PASSWORD=Admin@Secure123
